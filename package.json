{
  "name": "rhoai-feature-store",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "RHOAI UXD Prototypes - Feature Store implementation",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --check --write \"src/**/*.{ts,tsx}\"",
    "ci-checks": "npm run type-check && npm run lint"
  },
  "dependencies": {
    "@patternfly/react-core": "^6.4.0",
    "@patternfly/react-table": "^6.4.0",
    "@patternfly/react-icons": "^6.4.0",
    "@patternfly/react-charts": "^8.3.1",
    "@patternfly/react-code-editor": "^6.4.0",
    "@patternfly/chatbot": "^6.4.0",
    "@patternfly/react-styles": "^6.4.0",
    "@patternfly/react-templates": "^6.4.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^7.0.2",
    "react-syntax-highlighter": "^15.6.6"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@types/react-router-dom": "^5.3.3",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@typescript-eslint/eslint-plugin": "^8.17.0",
    "@typescript-eslint/parser": "^8.17.0",
    "@vitejs/plugin-react": "^4.2.1",
    "eslint": "^8.57.1",
    "eslint-plugin-react": "^7.37.2",
    "eslint-plugin-react-hooks": "^5.0.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "vite": "^5.1.0"
  }
}
